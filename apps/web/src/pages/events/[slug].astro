---
import { getEventBySlug } from '@clydeculture/shared';
import Layout from '../../components/Layout.astro';
import { getPublicQueryClient } from '../../lib/supabase';
import { asEventView, formatDateTime, sourceHref, sourceName } from '../../lib/viewData';

export const prerender = false;

const event = asEventView(await getEventBySlug(getPublicQueryClient(), Astro.params.slug ?? ''));

if (!event.title) {
  Astro.response.status = 404;
}
---

<Layout title={event.title ?? 'Event not found'}>
  {
    event.title ? (
      <article class="detail-grid">
        <div>
          <section class="page-heading">
            <h1>{event.title}</h1>
            <p class="lede">{formatDateTime(event.start_at)}</p>
          </section>
          {event.summary && <p>{event.summary}</p>}
          {sourceHref(event) && (
            <p>
              Source: {sourceName(event)} ·{' '}
              <a href={sourceHref(event)} rel="noreferrer">View original</a>
            </p>
          )}
        </div>
        <aside class="side-panel">
          <h2>Listing details</h2>
          <p>{event.event_types?.label ?? 'Event type to be confirmed'}</p>
          {event.venues?.slug ? (
            <p>
              <a href={`/venues/${event.venues.slug}`}>{event.venues.name}</a>
            </p>
          ) : (
            event.venues?.name && <p>{event.venues.name}</p>
          )}
          {event.festivals?.slug && (
            <p>
              <a href={`/?festival=${event.festivals.slug}`}>{event.festivals.name}</a>
            </p>
          )}
        </aside>
      </article>
    ) : (
      <p class="notice">This event is not available.</p>
    )
  }
</Layout>
