---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Clyde Culture</title>
    <style is:global>
      :root {
        color-scheme: light;
        --paper: #fbfaf7;
        --ink: #1c1e21;
        --muted: #60666d;
        --line: #d9d5cc;
        --green: #1f6f55;
        --blue: #244f8f;
        --rose: #a43f5f;
        --amber: #c87a22;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
      }

      a {
        color: var(--blue);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      .site-header {
        border-bottom: 1px solid var(--line);
        background: #ffffff;
      }

      .site-header__inner,
      main,
      .site-footer {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }

      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        min-height: 72px;
      }

      .brand {
        color: var(--ink);
        font-size: 1.25rem;
        font-weight: 750;
        text-decoration: none;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
      }

      nav a {
        color: var(--ink);
        font-size: 0.95rem;
      }

      main {
        padding: 36px 0 56px;
      }

      .page-heading {
        display: grid;
        gap: 10px;
        margin-bottom: 28px;
        max-width: 760px;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        margin-bottom: 0;
        font-size: clamp(2rem, 4vw, 3.8rem);
        line-height: 1.02;
        letter-spacing: 0;
      }

      h2 {
        font-size: 1.35rem;
      }

      .lede,
      .muted {
        color: var(--muted);
      }

      .lede {
        font-size: 1.08rem;
        line-height: 1.6;
      }

      .toolbar,
      .form-panel {
        display: grid;
        gap: 14px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #ffffff;
      }

      .toolbar {
        grid-template-columns: repeat(6, minmax(0, 1fr));
        margin-bottom: 26px;
      }

      label {
        display: grid;
        gap: 6px;
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 650;
      }

      input,
      textarea,
      button {
        box-sizing: border-box;
        width: 100%;
        min-height: 42px;
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 9px 11px;
        font: inherit;
      }

      textarea {
        min-height: 120px;
        resize: vertical;
      }

      button,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: auto;
        border-color: var(--green);
        background: var(--green);
        color: #ffffff;
        font-weight: 750;
        text-decoration: none;
      }

      .button--secondary {
        border-color: var(--line);
        background: #ffffff;
        color: var(--ink);
      }

      .event-list {
        display: grid;
        gap: 12px;
      }

      .event-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        padding: 18px;
        border: 1px solid var(--line);
        border-left: 5px solid var(--amber);
        border-radius: 8px;
        background: #ffffff;
      }

      .event-card h2,
      .event-card h3 {
        margin-bottom: 8px;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .source {
        align-self: center;
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        text-align: right;
      }

      .notice {
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-left: 5px solid var(--rose);
        border-radius: 8px;
        background: #ffffff;
      }

      .detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 28px;
      }

      .side-panel {
        align-self: start;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #ffffff;
      }

      .site-footer {
        padding: 22px 0 36px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 780px) {
        .site-header__inner,
        .event-card,
        .detail-grid {
          grid-template-columns: 1fr;
        }

        .site-header__inner {
          align-items: flex-start;
          flex-direction: column;
          padding: 18px 0;
        }

        .toolbar {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">Clyde Culture</a>
        <nav aria-label="Main navigation">
          <a href="/">Events</a>
          <a href="/tonight">Tonight</a>
          <a href="/this-weekend">This weekend</a>
          <a href="/submit">Submit your event</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Clyde Culture is a shared cultural noticeboard for Glasgow.
    </footer>
  </body>
</html>
