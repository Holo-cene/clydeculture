{
  "name": "clyde-culture",
  "private": true,
  "version": "0.0.0",
  "description": "Glasgow's shared cultural noticeboard — engine and documentation",
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset",
    "mvp:seed": "psql postgresql://postgres:postgres@127.0.0.1:54322/postgres -v ON_ERROR_STOP=1 -f supabase/seed.sql",
    "supabase:types": "supabase gen types typescript --local > packages/shared/src/database.types.ts",
    "ingest": "npx trigger.dev@latest dev"
  },
  "devDependencies": {
    "@trigger.dev/sdk": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
