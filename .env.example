# Supabase project credentials
# Obtain from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tier 1 API keys — Phase 1
TICKETMASTER_API_KEY=your-ticketmaster-key
SKIDDLE_API_KEY=your-skiddle-key
EVENTBRITE_API_KEY=your-eventbrite-key

# Tier 1 API keys — Phase 2
MEETUP_API_KEY=your-meetup-key
BANDSINTOWN_API_KEY=your-bandsintown-key

# Alert notifications — break detection emails are sent to this address
ALERT_EMAIL=your-email@example.com

# Never commit real secrets. Store values in environment variables locally
# (e.g. a .env file loaded by dotenv) and in Supabase Vault in production.
# See docs/OPERATIONS.md for the full secrets management guide.
