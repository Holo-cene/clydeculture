# Supabase project credentials
# Obtain from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key # Public anon key for apps/web (Astro) — scoped by RLS, safe to expose to browser

# Trigger.dev worker
TRIGGER_SECRET_KEY=your-trigger-secret-key # Required by the Trigger.dev worker — set in Trigger.dev project dashboard

# Tier 1 API keys — Phase 1
TICKETMASTER_API_KEY=your-ticketmaster-key
SKIDDLE_API_KEY=your-skiddle-key

# Apify connectors
APIFY_API_KEY=your-apify-key # Required for DICE.fm and Eventbrite Apify connectors (ADR 0003)

# Alert notifications — break detection
ALERT_EMAIL=your-email@example.com # Used by Trigger.dev to send task failure alerts — configure as a webhook or email in Trigger.dev dashboard

# Data Thistle — staging-only source (production display gated by source policy)
# Rotated refresh tokens must be updated in local .env / GitHub Actions secrets / Supabase Vault — never committed.
DATA_THISTLE_ACCESS_TOKEN=your-data-thistle-access-token
DATA_THISTLE_REFRESH_TOKEN=your-data-thistle-refresh-token
DATA_THISTLE_API_BASE_URL=https://api.datathistle.com/v1
DATA_THISTLE_AUTH_BASE_URL=https://auth.datathistle.com/v1 # Refresh endpoint base — the client calls {authBaseUrl}/refresh (every refresh rotates BOTH tokens; update them here/in secret stores, roughly monthly)

# ─── Phase 2 / unconfirmed sources ───────────────────────────────────────────
# MEETUP_API_KEY=      # Meetup API — P3, not yet confirmed as a connector path
# BANDSINTOWN_API_KEY=your-bandsintown-key

# Never commit real secrets. Store values in environment variables locally
# (e.g. a .env file loaded by dotenv) and in Supabase Vault in production.
# See docs/OPERATIONS.md for the full secrets management guide.
